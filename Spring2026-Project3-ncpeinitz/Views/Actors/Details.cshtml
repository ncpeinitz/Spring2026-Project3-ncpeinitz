@model Spring2026_Project3_ncpeinitz.ViewModels.ActorDetails

@{
    ViewData["Title"] = Model.Actor.Name;
}

<h1>@Model.Actor.Name</h1>

@if (Model.Actor.Photo != null)
{
    <img class="actor-image"
         src="data:image/jpeg;base64,@Convert.ToBase64String(Model.Actor.Photo)" alt="Photo of @Model.Actor.Name" />
}


<dl class="row">
    <dt class="col-sm-2">Age</dt>
    <dd class="col-sm-10">@Model.Actor.Age</dd>
    <dt class="col-sm-2">Gender</dt>
    <dd class="col-sm-10">@Model.Actor.Gender</dd>
    <dt class="col-sm-2">IMDb</dt>
    <dd class="col-sm-10">
        <a href="@Model.Actor.IMDbUrl" target="_blank">Open on IMDb</a>
    </dd>
</dl>

<h3>Movies</h3>
<ul>
    @foreach (var movie in Model.Movies)
    {
        <li>@movie</li>
    }
</ul>

<h3>Overall Sentiment: @Model.GeneralLabel (@Model.AverageScore.ToString("0.00"))</h3>

<table class="table table-striped">
    <thead>
        <tr>
            <th>AI Tweet</th>
            <th>Sentiment</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Tweets)
        {
            <tr>
                <td>@item.Text</td>
                <td>@item.Label (@item.Score.ToString("0.00"))</td>
            </tr>
        }
    </tbody>
</table>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Actor.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
