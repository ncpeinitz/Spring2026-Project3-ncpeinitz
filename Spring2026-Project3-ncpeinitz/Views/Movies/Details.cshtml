@model Spring2026_Project3_ncpeinitz.ViewModels.MovieDetails

@{
    ViewData["Title"] = Model.Movie.Title;
}

<h1>@Model.Movie.Title</h1>

@if (Model.Movie.Poster != null)
{
    <img class="poster-image"

    src="data:image/jpeg;base64,@Convert.ToBase64String(Model.Movie.Poster)" alt="Poster for @Model.Movie.Title" />
}


    <dl class="row">
        <dt class = "col-sm-2">Genre</dt>
        <dd class = "col-sm-10">@Model.Movie.Genre</dd>
        <dt class = "col-sm-2">Year Released</dt>
        <dd class = "col-sm-10">@Model.Movie.Year_Released</dd>
        <dt class = "col-sm-2">IMDb</dt>
        <dd class = "col-sm-10">
            <a href="@Model.Movie.IMDbUrl" target="_blank">Open on IMDb</a>
        </dd>
    </dl>

    <h3>Actors Starring in this Movie</h3>
    <ul>
        @foreach (var actor in Model.Actors)
        {
            <li>@actor</li>
        }
    </ul>

    <h3>Overall Sentiment: @Model.GeneralLabel (@Model.AverageScore.ToString("0.00"))</h3>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>AI Review</th>
                <th>Sentiment</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Reviews)
            {
            <tr>
                <td>@item.Text</td>
                <td>@item.Label (@item.Score.ToString("0.00"))</td>
            </tr>
        }
        </tbody>
    </table>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Movie.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
