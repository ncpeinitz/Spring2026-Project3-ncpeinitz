@{
    ViewData["Title"] = "Home Page";
}

<div class="home-hero text-center p-5 mb-4">
    <h1 class="display-4"> Movie & Actor Database</h1>
    <p class="lead">Browse movies and actors as well as read AI-generated reviews and tweets with sentiment analysis.</p>
    <a asp-controller="Movies" asp-action="Index" class="btn btn-light btn-lg me-2">Browse Movies</a>
    <a asp-controller="Actors" asp-action="Index" class="btn btn-outline-light btn-lg">Browse Actors</a>
</div>
